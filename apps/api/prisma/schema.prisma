generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id              String           @id @default(uuid())
  url             String
  company_name    String?
  description     String?
  industry        String?
  created_at      DateTime         @default(now())
  status          String           @default("pending")
  error           String?
  ai_insights     Json?
  architecture    Json?
  metadata        Json?
  technology_stack TechnologyStack?
  features        Feature[]
  competitors     Competitor[]
  cost_estimate   CostEstimate?
}

model TechnologyStack {
  id          String   @id @default(uuid())
  analysis_id String   @unique
  frontend    Json
  backend     Json
  database    Json
  hosting     Json
  analytics   Json
  payments    Json
  analysis    Analysis @relation(fields: [analysis_id], references: [id], onDelete: Cascade)
}

model Feature {
  id          String   @id @default(uuid())
  analysis_id String
  title       String
  description String
  analysis    Analysis @relation(fields: [analysis_id], references: [id], onDelete: Cascade)
}

model Competitor {
  id          String   @id @default(uuid())
  analysis_id String
  name        String
  description String
  analysis    Analysis @relation(fields: [analysis_id], references: [id], onDelete: Cascade)
}

model CostEstimate {
  id          String   @id @default(uuid())
  analysis_id String   @unique
  users_100   Json
  users_1000  Json
  users_10000 Json
  users_100000 Json
  analysis    Analysis @relation(fields: [analysis_id], references: [id], onDelete: Cascade)
}
